programa {
  funcao inicio() {
   inteiro nota1, nota2,nota3,nota4
   real media

   escreva ("Nota1:")
   leia (nota1)

   escreva ("Nota2:")
   leia (nota2)

   escreva ("Nota3:")
   leia(nota3)

   escreva ("Nota4:")
   leia (nota4)

   media=(nota1+nota2+nota3+nota4)/4
    escreva("A sua média e: ",media)
  }
}